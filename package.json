{
  "name": "ink-wasm",
  "version": "0.1.0",
  "description": "Google Ink (freehand stroke generation) compiled to WebAssembly, bundled with Rslib, with TypeScript types and Canvas2D / CanvasKit (Skia) rendering backends.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "playforge-coding",
  "homepage": "https://github.com/playforge-coding/ink-wasm#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/playforge-coding/ink-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/playforge-coding/ink-wasm/issues"
  },
  "keywords": [
    "ink",
    "google-ink",
    "wasm",
    "webassembly",
    "stroke",
    "freehand",
    "handwriting",
    "drawing",
    "stylus",
    "canvas",
    "canvaskit",
    "skia",
    "mesh"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer.d.ts",
      "import": "./dist/renderer.js"
    },
    "./ink.wasm": "./dist/ink.wasm",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.5.2",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "build:wasm": "node scripts/build-wasm.mjs",
    "build:js": "rslib build",
    "build": "node scripts/build.mjs",
    "test": "node scripts/test.mjs",
    "serve": "cd examples && cp -r ../dist ./ && pnpm dlx serve",
    "clean": "node scripts/clean.mjs",
    "prepublishOnly": "node -e \"const fs=require('fs');for(const f of ['dist/index.js','dist/index.d.ts','dist/ink.wasm'])fs.accessSync(f);console.log('dist artifacts present')\""
  },
  "devDependencies": {
    "@rslib/core": "^0.18.0",
    "@types/node": "^25.9.3",
    "typescript": "^5.9.0"
  }
}
